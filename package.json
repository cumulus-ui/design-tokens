{
  "name": "@cumulus-ui/design-tokens",
  "version": "0.4.4",
  "description": "CSS custom properties for Cumulus UI — light and dark mode tokens generated from Cloudscape Design System",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "test": "vitest run",
    "prepublishOnly": "tsx scripts/generate.ts"
  },
  "keywords": [
    "cloudscape",
    "design-tokens",
    "css-custom-properties",
    "dark-mode"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cumulus-ui/design-tokens"
  },
  "devDependencies": {
    "@cloudscape-design/components": "^3.0.1286",
    "@cloudscape-design/design-tokens": "^3.0.84",
    "@cloudscape-design/global-styles": "^1.0.58",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
